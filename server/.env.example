# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Required for the URL extraction feature. Get a key at https://openrouter.ai/keys
# Without this, the /api/extract-job endpoint returns a friendly error and the
# rest of the app works normally.
OPENROUTER_API_KEY=

# Optional — the model used for extraction. Any OpenRouter chat-completion
# model works. Known-reliable free-tier picks as of April 2026:
#   openai/gpt-oss-20b:free              — 131K ctx, stable, recommended default
#   inclusionai/ling-2.6-flash:free      — 262K ctx, fastest, cheapest tokens
#   z-ai/glm-4.5-air:free                — 131K ctx, works but burns reasoning tokens
# Avoid (silent empty-response bug):  minimax/minimax-m2.5:free,
# google/gemma-4-31b-it:free (often rate-limited upstream).
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# Optional server settings
PORT=3000
DB_PATH=./data/tracker.db
