# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Required for the URL extraction feature. Get a key at https://openrouter.ai/keys
# Without this, the /api/extract-job endpoint returns a friendly error and the
# rest of the app works normally.
OPENROUTER_API_KEY=

# Optional — the model used for extraction. Defaults to a free Gemini tier.
# Any OpenRouter-supported chat-completion model works.
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Optional server settings
PORT=3000
DB_PATH=./data/tracker.db
